@page "/admin/thanh-toan"
@model CoPuree.Web.Pages.Admin.PaymentSettingsModel
@{
    ViewData["Title"] = "Admin thanh toán";
    ViewData["Description"] = "Cấu hình thanh toán chuyển khoản CoPuree.";
}

<section class="admin-page">
    <div class="admin-heading">
        <div>
            <p class="eyebrow">CoPuree admin</p>
            <h1>Thanh toán</h1>
        </div>
        @if (Model.IsAuthenticated)
        {
            <div class="admin-actions">
                <a class="btn btn-outline-dark" asp-page="/Admin/Orders">Đơn hàng</a>
                <a class="btn btn-outline-dark" asp-page="/Admin/Products">Sản phẩm</a>
                <a class="btn btn-outline-dark" asp-page="/Admin/Customers">Khách hàng</a>
                <form method="post" asp-page-handler="Logout">
                    <button class="btn btn-outline-dark" type="submit">Đăng xuất</button>
                </form>
            </div>
        }
    </div>

    @if (!Model.IsAuthenticated)
    {
        <form method="post" asp-page-handler="Login" class="admin-login">
            <h2>Đăng nhập admin</h2>
            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <p class="text-danger">@Model.ErrorMessage</p>
            }
            <label for="password">Mật khẩu</label>
            <input id="password" class="form-control" asp-for="Password" type="password" autocomplete="current-password" />
            <button class="btn btn-primary" type="submit">Vào quản trị</button>
        </form>
    }
    else
    {
        <div class="admin-editor-layout">
            <form method="post" asp-page-handler="Save" class="admin-product-form">
                <h2>Cấu hình chuyển khoản</h2>
                @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
                {
                    <p class="text-success">@Model.SuccessMessage</p>
                }
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <label asp-for="Input.BankName">Ngân hàng</label>
                <input class="form-control" asp-for="Input.BankName" placeholder="VD: MB Bank" />
                <span asp-validation-for="Input.BankName" class="text-danger"></span>

                <label asp-for="Input.AccountNumber">Số tài khoản</label>
                <input class="form-control" asp-for="Input.AccountNumber" placeholder="Sẽ cập nhật khi bàn giao" />
                <span asp-validation-for="Input.AccountNumber" class="text-danger"></span>

                <label asp-for="Input.AccountName">Chủ tài khoản</label>
                <input class="form-control" asp-for="Input.AccountName" placeholder="VD: COPUREE" />
                <span asp-validation-for="Input.AccountName" class="text-danger"></span>

                <label asp-for="Input.Branch">Chi nhánh</label>
                <input class="form-control" asp-for="Input.Branch" placeholder="VD: Ho Chi Minh" />

                <label asp-for="Input.QrImageUrl">Ảnh QR chuyển khoản URL</label>
                <input class="form-control" asp-for="Input.QrImageUrl" placeholder="/images/payment/qr-bank.png hoặc URL ảnh" />

                <label asp-for="Input.TransferContentPrefix">Tiền tố nội dung chuyển khoản</label>
                <input class="form-control" asp-for="Input.TransferContentPrefix" placeholder="COPUREE" />
                <span asp-validation-for="Input.TransferContentPrefix" class="text-danger"></span>

                <button class="btn btn-primary" type="submit">Lưu cấu hình</button>
            </form>

            <article class="detail-panel">
                <h2>Khách sẽ nhìn thấy</h2>
                <div class="detail-lines">
                    <div><span>Ngân hàng</span><strong>@Model.Input.BankName</strong></div>
                    <div><span>Số tài khoản</span><strong>@Model.Input.AccountNumber</strong></div>
                    <div><span>Chủ tài khoản</span><strong>@Model.Input.AccountName</strong></div>
                    <div><span>Nội dung mẫu</span><strong>@Model.Input.TransferContentPrefix CP260527000000</strong></div>
                </div>
                <p class="mt-3">Khi có đơn mới, trang thành công sẽ gợi ý nội dung chuyển khoản theo mã đơn để đối soát nhanh hơn.</p>
            </article>
        </div>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
