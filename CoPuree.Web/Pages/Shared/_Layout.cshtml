@using CoPuree.Web.Services
@using Microsoft.Extensions.Options
@inject IOptions<BrandOptions> BrandOptions
@{
    var brand = BrandOptions.Value;
    var isAdmin = Context.Request.Path.StartsWithSegments("/admin");
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @brand.Name</title>
    <meta name="description" content="@(ViewData["Description"] ?? "CoPuree - dầu dừa ép lạnh, câu chuyện sản phẩm và nội dung chăm sóc hằng ngày.")" />
    <meta property="og:title" content="@ViewData["Title"] - @brand.Name" />
    <meta property="og:description" content="@(ViewData["Description"] ?? "CoPuree - dầu dừa ép lạnh cho self-care và căn bếp.")" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/brand/hero-product.png" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CoPuree.Web.styles.css" asp-append-version="true" />
</head>
<body class="@(isAdmin ? "admin-body" : null)">
    <header class="site-header @(isAdmin ? "admin-site-header" : null)">
        <nav class="navbar navbar-expand-lg">
            <div class="container-fluid site-shell">
                <a class="brand-mark" asp-page="@(isAdmin ? "/Admin/Articles" : "/Index")">
                    @if (!string.IsNullOrWhiteSpace(brand.LogoUrl))
                    {
                        <img src="@brand.LogoUrl" alt="@brand.Name" />
                    }
                    else
                    {
                        <span>Co</span>@:Puree
                    }
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    @if (isAdmin)
                    {
                        <ul class="navbar-nav mx-auto nav-main">
                            <li class="nav-item"><a class="nav-link" asp-page="/Admin/Articles">Bài viết</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Admin/Products">Sản phẩm</a></li>
                            <li class="nav-item"><a class="nav-link" href="http://localhost:3000" target="_blank" rel="noopener">Xem website</a></li>
                        </ul>
                        <span class="admin-mode-pill">Content studio</span>
                    }
                    else
                    {
                        <ul class="navbar-nav mx-auto nav-main">
                            <li class="nav-item"><a class="nav-link" asp-page="/Index">Trang chủ</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Products">Sản phẩm</a></li>
                            <li class="nav-item"><a class="nav-link" href="/#story">Câu chuyện</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/ShippingPolicy">Liên hệ</a></li>
                        </ul>
                        <a class="nav-icon" href="tel:@brand.Hotline" aria-label="Gọi CoPuree">Gọi</a>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main class="site-shell @(isAdmin ? "admin-shell" : null)">
        @RenderBody()
    </main>

    @if (!isAdmin)
    {
        <footer class="site-footer">
            <div class="site-shell footer-grid">
                <div>
                    <a class="brand-mark" asp-page="/Index"><span>Co</span>Puree</a>
                    <p>Dầu dừa ép lạnh cho self-care, căn bếp và nhịp sống tự nhiên mỗi ngày.</p>
                </div>
                <div>
                    <strong>Thương hiệu</strong>
                    <p>CoPuree tập trung giới thiệu sản phẩm, câu chuyện nguyên liệu và nội dung chăm sóc hữu ích.</p>
                </div>
                <div>
                    <strong>Liên hệ</strong>
                    <p>Hotline: <a href="tel:@brand.Hotline">@brand.Hotline</a><br />Email: <a href="mailto:@brand.Email">@brand.Email</a><br />Địa chỉ: @brand.WarehouseAddress</p>
                    <a class="footer-social" href="@brand.FacebookUrl" target="_blank" rel="noopener">Facebook CoPuree</a>
                </div>
                <div class="footer-links">
                    <strong>Quản trị</strong>
                    <a asp-page="/Admin/Articles">Bài viết</a>
                    <a asp-page="/Admin/Products">Sản phẩm</a>
                </div>
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
