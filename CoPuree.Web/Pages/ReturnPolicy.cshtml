@page "/doi-tra-hoan-tien"
@model ReturnPolicyModel
@{
    ViewData["Title"] = "Doi tra va hoan tien";
    ViewData["Description"] = "Chinh sach doi tra san pham dau dua CoPuree khi hang loi, hu hong hoac giao sai.";
}

<section class="policy-page">
    <p class="eyebrow">Ho tro sau mua</p>
    <h1>Doi tra va hoan tien</h1>
    <p>CoPuree ho tro doi tra khi san pham bi loi dong goi, hu hong trong qua trinh van chuyen, giao sai san pham hoac sai so luong.</p>
    <h2>Dieu kien doi tra</h2>
    <p>Khach hang lien he trong vong 48 gio sau khi nhan hang, kem hinh anh san pham va ma don hang de CoPuree kiem tra.</p>
    <h2>Hinh thuc xu ly</h2>
    <p>Tuy truong hop, CoPuree se doi san pham moi, gui bu phan thieu hoac hoan tien theo phuong thuc thanh toan ban dau.</p>
</section>
