@page "/gio-hang"
@model CartModel
@{
    ViewData["Title"] = "Gio hang";
}

<section class="cart-layout">
    <div>
        <p class="eyebrow">Gio hang</p>
        <h1>Don hang CoPuree cua ban</h1>

        @if (!Model.Cart.Items.Any())
        {
            <div class="empty-state">
                <h2>Gio hang dang trong</h2>
                <p>Hay chon san pham dau dua phu hop de bat dau don hang.</p>
                <a class="btn btn-primary" asp-page="/Products">Xem san pham</a>
            </div>
        }
        else
        {
            <div class="cart-lines">
                @foreach (var item in Model.Cart.Items)
                {
                    <article class="cart-line">
                        <img src="@item.Product.ImageUrl" alt="@item.Product.Name" />
                        <div>
                            <h2>@item.Product.Name</h2>
                            <p>@item.Product.Size</p>
                            <strong>@item.Product.Price.ToString("N0") d</strong>
                            <span class="stock-hint">Con @item.Product.StockQuantity san pham</span>
                        </div>
                        <form method="post" asp-page-handler="Update" class="quantity-form">
                            <input type="hidden" name="productId" value="@item.Product.Id" />
                            <input class="form-control" type="number" name="quantity" value="@item.Quantity" min="1" max="@Math.Min(99, item.Product.StockQuantity)" />
                            <button class="btn btn-outline-dark" type="submit">Cap nhat</button>
                        </form>
                        <form method="post" asp-page-handler="Remove">
                            <input type="hidden" name="productId" value="@item.Product.Id" />
                            <button class="btn btn-link text-danger" type="submit">Xoa</button>
                        </form>
                    </article>
                }
            </div>
        }
    </div>

    <aside class="order-summary">
        <h2>Tam tinh</h2>
        <div><span>San pham</span><strong>@Model.Cart.Subtotal.ToString("N0") d</strong></div>
        <div><span>Van chuyen</span><strong>@Model.Cart.ShippingFee.ToString("N0") d</strong></div>
        <div class="summary-total"><span>Tong</span><strong>@Model.Cart.Total.ToString("N0") d</strong></div>
        <a class="btn btn-primary w-100 @(Model.Cart.Items.Any() ? "" : "disabled")" asp-page="/Checkout">Thanh toan</a>
    </aside>
</section>
